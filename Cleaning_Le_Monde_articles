ll,"outputs":[]},{"cell_type":"code","source":["#εισάγω τη βιβιοθήκη re για δημιουργία regex (regular expressions)-δηλαδή κανόνες αναζήτησης και εντοπισμού μοτίβων\n","import re"],"metadata":{"id":"PogNpgbW5A7t"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# δημιουργώ regex patterns που εντοπίζουν προβληματικά μοτίβα για βασικό καθαρισμό κειμένου (δηλ. τι ψάχνω)\n","\n","url      = re.compile(r'https?://\\S+|www\\.\\S+')  # εντοπίζει URLs/links\n","dashes   = re.compile(r'[-–—−]+')                # εντοπίζει όλα τα είδη παύλας (– — − κτλ.) και τα κανονικοποιεί\n","quotes   = re.compile(r'[“”]')                   # εντοπίζει “curly” διπλά εισαγωγικά\n","apos     = re.compile(r'[’]')                    # εντοπιζει το curly απόστροφο (’)\n","spaces   = re.compile(r'\\s+')                    # εντοπίζει πολλά συνεχόμενα κενά\n"],"metadata":{"id":"oZ9NjbM41rDr"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# φτιάχνω συνάρτηση που εφαρμόζει τα παραπάνω μοτίβα και κάνει την πραγματική κανονικοποίηση του κειμένου (δηλ. τι κάνω όταν εντοπίσω το πρόβλημα)\n","# ηπιος καθαρισμός, δεν αφαιρούμε τη στίξη (τη χρειαζόμαστε για sentencization)\n","\n","def mild_text_clean(text: str) -> str:\n","\n","    text = str(text)\n","\n","    text = url.sub(\" \", text)        # αφαιρεί links\n","    text = dashes.sub(\" — \", text)   # ενοποιεί τις παύλες σε em dash\n","    text = quotes.sub('\"', text)     # κάνει “ ” → \"\n","    text = apos.sub(\"'\", text)       # κάνει ’ → '\n","    text = spaces.sub(\" \", text).strip()  # αφαιρεί περιττά κενά\n","\n","    return text\n"],"metadata":{"id":"eCPFmc5uvpty"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#εφαρμοζω τη συναρτηση και αποθηκεύω σε νέα στήλη\n","\n","df[\"text_clean\"] = df[\"text\"].apply(mild_text_clean)"],"metadata":{"id":"uNee0JA32wtn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# check\n","df.tail()"],"metadata":{"id":"DsLdOjSqFFgW"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["### Κι άλλο καθαρισμα"],"metadata":{"id":"yg9-NLmeNhSD"}},{"cell_type":"code","source":["# πιο 'επιθετικό' καθαρισμα για περαιτέρω εφαρμογές όπως π.χ. αν θέλω να τρέξω καποιο λεξικό στα κείμενα μου (π.χ. ρητορικής μίσους)\n","\n","def clean_text(article: str) -> str:\n","    s = str(article).lower() # mετατρέπει το κείμενο σε string και όλα τα γράμματα σε πεζά\n","    s = re.sub(r'[' + re.escape(string.punctuation) + r'’“”–—]', ' ', s) # αντικαθιστά όλα τα σημεία στίξης με κενό\n","    s = re.sub(r'\\s+', ' ', s).strip() # Αααιρεί τα περιττά κενά ανάμεσα στις λέξεις\n","\n","    return s"],"metadata":{"id":"un44yQmGNt1d"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#εφαρμοζω τη συναρτηση και αποθηκεύω σε νέα στήλη\n","\n","df['tokenized'] = df['text_clean'].map(lambda x: clean_text(x))"],"metadata":{"id":"LUlg6cRpFC4w"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["df.tail()"],"metadata":{"id":"Gpb-X4dQNljo"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["### Αφαίρεση Stopwords"],"metadata":{"id":"azy7eUd2OFDA"}},{"cell_type":"code","source":["# εισάγω βιβλιοθήκες και εργαλεία για tokenization και stopwords\n","\n","# η βιβλιοθήκη string περιέχει έτοιμους χαρακτήρες και εργαλεία για επεξεργασία κειμένου\n","import string\n","\n","#η nltk (Natural Language Toolkit) χρησιμοποιείται για βασικές εργασίες NLP (Natural Language Processing) όπως tokenization, stopwords κτλ.\n","import nltk\n","\n","# κατεβάζω το tokenizer μοντέλο punkt που χρησιμοποιείται για sentence splitting και tokenization\n","nltk.download('punkt')\n","nltk.download('punkt_tab')\n","\n","# παίρνω όλα τα σημεία στίξης και τα αποθηκεύω σε λίστα\n","punct = list(set(string.punctuation))\n","\n","## εισάγω τα stopwords της NLTK\n","from nltk.corpus import stopwords\n","\n","#εισάγω tokenizer για να χωρίσω το κείμενο σε λέξεις/tokens\n","from nltk.tokenize import word_tokenize\n","\n","# κατεβάζω τη λίστα stopwords\n","nltk.download('stopwords')\n","\n","## δημιουργώ set με τα αγγλικά stopwords\n","stop_words = set(stopwords.words('english'))"],"metadata":{"id":"yjTktJ8DFC-S"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# δημιουργώ συνάρτηση που αφαιρεί τα stop words\n","\n","def remove_stopwords(x):\n","    # works whether x is a list of tokens or a raw string\n","    tokens = x if isinstance(x, (list, tuple)) else word_tokenize(str(x))\n","    return [t for t in tokens if t.lower() not in stop_words]"],"metadata":{"id":"sfTIS3lEFMXh"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#εφαρμοζω τη συναρτηση και αποθηκεύω σε νέα στήλη\n","\n","df['no_stop'] = df['tokenized'].apply(remove_stopwords)\n"],"metadata":{"id":"8aVUV92AFMZ-"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["df.head(2)"],"metadata":{"id":"Nr5ObPDeOR95"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["### Τσεκάρω μερικές συχνότητες"],"metadata":{"id":"TqFAnGtmOSsh"}},{"cell_type":"code","source":["# συχνότητα λέξεων ανα κείμενο\n","df['num_wds'] = df['tokenized'].apply(lambda x: len(x.split()))#αποθηκεύω τον αριθμό λέξεων του άρθρου σε δική του στήλη\n","df['num_wds'].mean()"],"metadata":{"id":"Qc7hUyXnFMc4"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# συχνότητα μοναδικών λέξεων ανα κείμενο\n","df['uniq_wds'] = df['tokenized'].str.split().apply(lambda x: len(set(x))) #αποθηκεύω τον αριθμό μοναδικών λεξεων του άρθρου σε δική του στήλη\n","df['uniq_wds'].mean()"],"metadata":{"id":"cbetfp8BFMhu"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# δημιουργώ στήλη Text_id για να μην χάνω τα κείμενα\n","df = df.reset_index().rename(columns={'index': 'Text_id'})"],"metadata":{"id":"WQ-Js2L6UXfy"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["df.head()"],"metadata":{"id":"Yzeb1CuaFMkn"},"execution_count":nu