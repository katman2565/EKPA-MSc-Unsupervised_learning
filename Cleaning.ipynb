    {
      "cell_type": "markdown",
      "source": [
        "### Mη επιθετικός καθαρισμός κειμένου"
      ],
      "metadata": {
        "id": "JyoaPNJkKARn"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# βεβαιώνομαι ότι οι κενές γραμμές δεν περιέχουν NaN τιμές αλλά κενό string\n",
        "df['text'] = df['text'].fillna('')\n"
      ],
      "metadata": {
        "id": "J0n81Vz3LoBb"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "## δημιουργώ regex patterns για βασικό καθαρισμό κειμένου\n",
        "\n",
        "RE_DASHES   = re.compile(r'[-–—−]+') # εντοπίζει όλα τα είδη παύλας (– — − κτλ.) και τα ενοποιεί\n",
        "RE_QUOTES   = re.compile(r'[“”]')# αντικαθιστά τα “curly” διπλά εισαγωγικά με κανονικά \"\n",
        "RE_APOS     = re.compile(r'[’]')# αντικαθιστά το curly απόστροφο ’ με κανονικό '\n",
        "RE_URL      = re.compile(r'https?://\\S+|www\\.\\S+') # εντοπίζει URLs/links (http, https, www)\n",
        "RE_SPACE_S  = re.compile(r'\\b([A-Za-z]{2,})\\s+s\\b') # διορθώνει περιπτώσεις όπως \"there s\" → \"there's\"\n",
        "RE_SPACE_VE = re.compile(\n",
        "    r'\\b(I|i|we|We|they|They|you|You|could|Could|should|Should|would|Would)\\s+ve\\b'  # Διορθώνει περιπτώσεις όπως \"we ve\" → \"we've\"\n",
        "\n",
        ")\n",
        "\n",
        "# συνάρτηση βασικού normalization του κειμένου\n",
        "\n",
        "def normalize_basic(s: str) -> str:\n",
        "\n",
        "    s = RE_URL.sub(' ', s) # αφαιρεί URLs από το κείμενο\n",
        "    s = RE_DASHES.sub(' — ', s) # ενοποιεί διαφορετικά είδη παύλας σε em-dash\n",
        "    s = RE_QUOTES.sub('\"', s) # μετατρέπει τα curly quotes σε κανονικά \"\n",
        "    s = RE_APOS.sub(\"'\", s) # μετατρέπει το curly apostrophe σε κανονικό '\n",
        "    s = RE_SPACE_S.sub(r\"\\1's\", s) # διορθώνει \"there s\" → \"there's\"\n",
        "    s = RE_SPACE_VE.sub(lambda m: m.group(1) + \"'ve\", s)\n",
        "    s = re.sub(r'\\s+', ' ', s).strip() # αφαιρεί περιττά κενά\n",
        "\n",
        "    return s\n",
        "\n",
        "# ήπιος καθαρισμός χωρίς αφαίρεση punctuation ή αλλαγή κεφαλαίων\n",
        "def non_aggresive_clean(s: str) -> str:\n",
        "\n",
        "    # Κρατά punctuation και κεφαλαία/πεζά,\n",
        "    # διορθώνει μόνο τεχνικά artifacts\n",
        "    return normalize_basic(s)"
      ],
      "metadata": {
        "id": "4mW20ePLMqhz"
      },
      "execution_count": null,
      "outputs": []
    },
    {
