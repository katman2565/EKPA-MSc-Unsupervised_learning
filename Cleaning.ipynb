    {
      "cell_type": "markdown",
      "source": [
        "### Κι άλλο καθαρισμα"
      ],
      "metadata": {
        "id": "yg9-NLmeNhSD"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# πιο επιθετικό καθαρισμμα για περαιτέρω εφαρμογές όπως π.χ. αν θέλω να τρέξω καποιο λεξικό στα κείμενα μου π.χ. ρητορικής μίσους\n",
        "\n",
        "def clean_text(article: str) -> str:\n",
        "    s = str(article).lower() # mετατρέπει το κείμενο σε string και όλα τα γράμματα σε πεζά\n",
        "    s = re.sub(r'[' + re.escape(string.punctuation) + r'’“”–—]', ' ', s) # αντικαθιστά όλα τα σημεία στίξης με κενό\n",
        "    s = re.sub(r'\\s+', ' ', s).strip() # Αααιρεί τα περιττά κενά ανάμεσα στις λέξεις\n",
        "\n",
        "    return s"
      ],
      "metadata": {
        "id": "un44yQmGNt1d"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#αποθηκεύσω σε νέα στήλη\n",
        "df['tokenized'] = df['text_clean'].map(lambda x: clean_text(x))"
      ],
