    {
      "cell_type": "markdown",
      "source": [
        "### Αφαίρεση Stopwords"
      ],
      "metadata": {
        "id": "azy7eUd2OFDA"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# εισάγω βιβλιοθήκες και εργαλεία για tokenization και stopwords\n",
        "\n",
        "import string\n",
        "import nltk\n",
        "nltk.download('punkt')\n",
        "nltk.download('punkt_tab')\n",
        "punct = list(set(string.punctuation))\n",
        "from nltk.corpus import stopwords\n",
        "from nltk.tokenize import word_tokenize\n",
        "nltk.download('stopwords')\n",
        "stop_words = set(stopwords.words('english'))"
      ],
      "metadata": {
        "id": "yjTktJ8DFC-S"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# δημιουργώ συνάρτηση που αφαιρεί τα stop words\n",
        "\n",
        "def remove_stopwords(x):\n",
        "    # works whether x is a list of tokens or a raw string\n",
        "    tokens = x if isinstance(x, (list, tuple)) else word_tokenize(str(x))\n",
        "    return [t for t in tokens if t.lower() not in stop_words]"
      ],
      "metadata": {
        "id": "sfTIS3lEFMXh"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#αποθηκεύω\n",
        "\n",
        "df['no_stop'] = df['tokenized'].apply(remove_stopwords)\n"
      ],
      "metadata": {
        "id": "8aVUV92AFMZ-"
